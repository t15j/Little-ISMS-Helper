{% extends 'base.html.twig' %}
{% trans_default_domain 'privacy' %}

{% block title %}{{ 'privacy.data_breach.page.edit_title'|trans({}, 'privacy') }} - {{ breach.referenceNumber }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'privacy.breadcrumb.privacy'|trans({}, 'privacy'), icon: 'bi-shield-lock' },
            { label: 'privacy.breadcrumb.data_breaches'|trans({}, 'privacy'), url: path('app_data_breach_index') },
            { label: breach.referenceNumber, url: path('app_data_breach_show', {id: breach.id}) },
            { label: 'privacy.data_breach.page.edit_title'|trans({}, 'privacy') }
        ]
    } %}

    {% include '_components/_page_header.html.twig' with {
        title: 'privacy.data_breach.page.edit_title'|trans({}, 'privacy'),
        subtitle: 'privacy.data_breach.page.edit_subtitle'|trans({'%ref%': breach.referenceNumber, '%title%': breach.title}, 'privacy'),
        icon: 'bi-pencil',
        actions: [
            { label: 'common.cancel'|trans({}, 'messages'), url: path('app_data_breach_show', {id: breach.id}), variant: 'secondary', icon: 'bi-x-lg' }
        ]
    } %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header"><h2 class="mb-0"><i class="fa-icon fa-icon--sop" aria-hidden="true"></i> {{ 'privacy.data_breach.form.title'|trans({}, 'privacy') }}</h2></div>
        {% endblock %}
        {% block card_body %}
            {{ form_start(form) }}
                {% include '_components/_auto_form.html.twig' with {
                    'form': form,
                    'sections': {
                        'basic_info': {
                            'label': '<i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i> Basic Information'|raw,
                            'fields': ['title', 'incident', 'processingActivity']
                        },
                        'notification_content': {
                            'label': '<i class="fa-icon fa-icon--policy" aria-hidden="true"></i> Art. 33(3) - Content of Notification'|raw,
                            'fields': ['affectedDataSubjects', 'dataCategories', 'dataSubjectCategories', 'breachNature', 'likelyConsequences', 'measuresTaken', 'mitigationMeasures']
                        },
                        'risk_assessment': {
                            'label': '<i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> Risk Assessment'|raw,
                            'fields': ['riskLevel', 'riskAssessment', 'specialCategoriesAffected', 'criminalDataAffected']
                        },
                        'notification_requirements': {
                            'label': '<i class="fa-icon fa-icon--ui-bell" aria-hidden="true"></i> Notification Requirements'|raw,
                            'fields': ['requiresAuthorityNotification', 'requiresSubjectNotification', 'noSubjectNotificationReason']
                        },
                        'investigation': {
                            'label': '<i class="fa-icon fa-icon--ui-search" aria-hidden="true"></i> Investigation & Follow-up'|raw,
                            'fields': ['rootCause', 'lessonsLearned']
                        },
                        'responsible_persons': {
                            'label': '<i class="fa-icon fa-icon--ui-person" aria-hidden="true"></i> Responsible Persons'|raw,
                            'fields': ['dataProtectionOfficer', 'dataProtectionOfficerPerson', 'dataProtectionOfficerDeputyPersons', 'assessorPerson', 'assessorDeputyPersons']
                        }
                    },
                    'col_widths': {
                        'title': 8,
                        'incident': 6,
                        'processingActivity': 6,
                        'affectedDataSubjects': 12,
                        'dataCategories': 12,
                        'dataSubjectCategories': 12,
                        'breachNature': 12,
                        'likelyConsequences': 12,
                        'measuresTaken': 12,
                        'mitigationMeasures': 12,
                        'riskLevel': 6,
                        'riskAssessment': 6,
                        'specialCategoriesAffected': 6,
                        'criminalDataAffected': 6,
                        'requiresAuthorityNotification': 6,
                        'requiresSubjectNotification': 6,
                        'noSubjectNotificationReason': 12,
                        'rootCause': 12,
                        'lessonsLearned': 12,
                        'dataProtectionOfficer': 6,
                        'dataProtectionOfficerPerson': 6,
                        'dataProtectionOfficerDeputyPersons': 12,
                        'assessorPerson': 6,
                        'assessorDeputyPersons': 6
                    },
                    'tooltips': {
                        'affectedDataSubjects': 'data_breach.tooltip.affected_data_subjects',
                        'riskLevel': 'data_breach.tooltip.risk_level'
                    },
                    'translation_domain': 'privacy'
                } %}

                <div class="mt-4">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                        <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'privacy.data_breach.action.update'|trans({}, 'privacy') }}
                    </button>
                    <a href="{{ path('app_data_breach_show', {id: breach.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i> {{ 'common.cancel'|trans({}, 'messages') }}
                    </a>
                </div>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
