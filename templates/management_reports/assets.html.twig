{% extends 'base.html.twig' %}
{% trans_default_domain 'management_reports' %}

{% block title %}{{ 'management_reports.assets.title'|trans({}, 'management_reports') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.reports'|trans({}, 'nav'), path: 'app_reports_index' },
            { label: 'management_reports.title'|trans({}, 'management_reports'), path: 'app_management_reports' },
            { label: 'management_reports.assets.title'|trans({}, 'management_reports') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">
            <i class="fa-icon fa-icon--asset-server fa-icon--muted" aria-hidden="true"></i> {{ 'management_reports.assets.title'|trans({}, 'management_reports') }}
        </h1>
        <div class="btn-group">
            <a href="{{ path('app_management_reports_assets_pdf') }}" class="fa-cyber-btn fa-cyber-btn--danger">
                <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> {{ 'management_reports.action.download_pdf'|trans({}, 'management_reports') }}
            </a>
            <a href="{{ path('app_management_reports_assets_excel') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="bi bi-file-excel" aria-hidden="true"></i> {{ 'management_reports.action.download_excel'|trans({}, 'management_reports') }}
            </a>
        </div>
    </div>

    {# Total Assets #}
    <div class="row mb-4">
        <div class="col-md-4">
            {{ _fa_feature_card.render({
                icon: 'server',
                label: 'management_reports.assets.total'|trans({}, 'management_reports'),
                value: report.total_assets,
                variant: 'primary'
            }) }}
        </div>
        <div class="col-md-8">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h5 mb-0">
                            <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i>
                            {{ 'management_reports.assets.by_type'|trans({}, 'management_reports') }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if report.by_type|length > 0 %}
                    <div class="row">
                        {% for type, count in report.by_type %}
                        <div class="col-md-4 mb-2">
                            <div class="d-flex justify-content-between">
                                <span>{{ type }}</span>
                                {% include '_components/_badge.html.twig' with { variant: 'primary', content: count } %}
                            </div>
                            <div class="progress progress-h-8">
                                <div class="progress-bar" style="width: {{ report.total_assets > 0 ? (count / report.total_assets * 100) : 0 }}%"></div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="fa-alert fa-alert--info mb-0" role="alert">
                        {{ 'management_reports.assets.no_assets'|trans({}, 'management_reports') }}
                    </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Classification Breakdown #}
    {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm mb-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="h5 mb-0">
                    <i class="fa-icon fa-icon--control" aria-hidden="true"></i>
                    {{ 'management_reports.assets.by_classification'|trans({}, 'management_reports') }}
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if report.by_classification|length > 0 %}
            <div class="row">
                {% for classification, count in report.by_classification %}
                    {% set code = classification|lower %}
                    {% set is_known = code in ['public','internal','confidential','restricted'] %}
                    {% set label = is_known ? ('asset.classification.' ~ code)|trans({}, 'asset') : classification %}
                <div class="col-md-3 text-center mb-3">
                    <div class="border rounded p-3 h-100">
                        <h4 class="{% if code in ['confidential','restricted'] %}text-danger{% elseif code == 'internal' %}text-warning{% else %}text-success{% endif %}">
                            {{ count }}
                        </h4>
                        <small class="text-muted">{{ label }}</small>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="fa-alert fa-alert--info mb-0" role="alert">
                {{ 'management_reports.assets.no_classification'|trans({}, 'management_reports') }}
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Asset Table #}
    {% if report.assets|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm mb-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="h5 mb-0">
                    <i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i>
                    {{ 'management_reports.assets.inventory'|trans({}, 'management_reports') }}
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th scope="col">{{ 'management_reports.assets.header.id'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.assets.header.name'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.assets.header.type'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.assets.header.classification'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.assets.header.owner'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.assets.header.status'|trans({}, 'management_reports') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for asset in report.assets|slice(0, 50) %}
                        <tr>
                            <td>{{ asset.id }}</td>
                            <td>
                                <a href="{{ path('app_asset_show', {id: asset.id}) }}">
                                    {{ asset.name }}
                                </a>
                            </td>
                            <td>{{ asset.assetType }}</td>
                            <td>
                                {% set code = (asset.dataClassification ?? '')|lower %}
                                {% set is_known = code in ['public','internal','confidential','restricted'] %}
                                {% set label = is_known ? ('asset.classification.' ~ code)|trans({}, 'asset') : ('management_reports.assets.no_classification'|trans({}, 'management_reports')) %}
                                {% set variant = (code in ['confidential','restricted']) ? 'danger' : (code == 'internal' ? 'warning' : (code == 'public' ? 'success' : 'secondary')) %}
                                {% include '_components/_badge.html.twig' with { variant: variant, content: label } %}
                            </td>
                            <td>{{ asset.effectiveOwner ?? '-' }}</td>
                            <td>{{ asset.status|default('Active') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% if report.assets|length > 50 %}
            <div class="text-muted text-center mt-2">
                {{ 'management_reports.assets.showing_first'|trans({'%count%': 50, '%total%': report.assets|length}, 'management_reports') }}
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Quick Links #}
    {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm mb-4' } %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-6">
                    <a href="{{ path('app_asset_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost w-100">
                        <i class="fa-icon fa-icon--asset-server" aria-hidden="true"></i> {{ 'management_reports.assets.view_all'|trans({}, 'management_reports') }}
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="{{ path('app_management_reports_assets_excel') }}" class="fa-cyber-btn fa-cyber-btn--ghost w-100">
                        <i class="bi bi-file-excel" aria-hidden="true"></i> {{ 'management_reports.assets.export_full'|trans({}, 'management_reports') }}
                    </a>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# Report Generated Info #}
    <div class="text-muted small text-end">
        <i class="fa-icon fa-icon--ui-clock" aria-hidden="true"></i>
        {{ 'management_reports.generated_at'|trans({}, 'management_reports') }}: {{ report.generated_at|date('Y-m-d H:i') }}
    </div>
</div>
{% endblock %}
