{% extends 'base.html.twig' %}
{% trans_default_domain 'management_review' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'management_review.edit'|trans({}, 'management_review') }} - {{ review.title }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_management_review_index') }}" data-turbo-action="advance">
                    <i class="bi bi-clipboard2-check" aria-hidden="true"></i> {{ 'management_review.title'|trans({}, 'management_review') }}
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path('app_management_review_show', {id: review.id}) }}" data-turbo-action="advance">
                    {{ review.title }}
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'common.edit'|trans({}, 'messages') }}</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'management_review.edit'|trans({}, 'management_review') }}: {{ review.title }}
        </h1>
    </div>

    <div class="row">
        <div class="col-lg-10 col-xl-9 mx-auto">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="h5 mb-0">
                            <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'management_review.edit'|trans({}, 'management_review') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_alert.html.twig' as _fa_alert %}
                    {{ _fa_alert.render({ variant: 'info', class: 'mb-4', title: 'management_review.iso_requirement'|trans({}, 'management_review'), body: '<span class="small">' ~ 'management_review.iso_clause_93_info'|trans({}, 'management_review') ~ '</span>' }) }}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    {% include '_components/_auto_form.html.twig' with {
                        'form': form,
                        'sections': {
                            'basic_info': {
                                'label': 'management_review.section.basic_info'|trans({}, 'management_review'),
                                'fields': ['title', 'reviewDate', 'participants', 'reviewedBy', 'reviewedByPerson', 'reviewedByDeputyPersons', 'status']
                            },
                            'inputs': {
                                'label': 'management_review.section.inputs'|trans({}, 'management_review'),
                                'fields': ['changesRelevantToISMS', 'feedbackFromInterestedParties', 'auditResults', 'performanceEvaluation']
                            },
                            'followup': {
                                'label': 'management_review.section.followup'|trans({}, 'management_review'),
                                'fields': ['previousReviewActions', 'nonConformitiesStatus', 'correctiveActionsStatus']
                            },
                            'outputs': {
                                'label': 'management_review.section.outputs'|trans({}, 'management_review'),
                                'fields': ['opportunitiesForImprovement', 'resourceNeeds', 'decisions', 'actionItems']
                            }
                        },
                        'col_widths': {
                            'title': 8,
                            'reviewDate': 4,
                            'reviewedBy': 6,
                            'reviewedByPerson': 6,
                            'reviewedByDeputyPersons': 12,
                            'status': 6
                        }
                    } %}

                    {# Form Actions #}
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <div>
                            <a href="{{ path('app_management_review_show', {id: review.id}) }}"
                               class="fa-cyber-btn fa-cyber-btn--ghost"
                               data-turbo-action="advance">
                                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
                            </a>
                            <a href="{{ path('app_management_review_index') }}"
                               class="fa-cyber-btn fa-cyber-btn--ghost"
                               data-turbo-action="advance">
                                <i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i> {{ 'common.to_list'|trans({}, 'messages') }}
                            </a>
                        </div>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
                            <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'common.save_changes'|trans({}, 'messages') }}
                        </button>
                    </div>

                    {{ form_end(form) }}
                {% endblock %}
            {% endembed %}

            {# Metadata Card #}
            {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="h5 mb-0"><i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i> {{ 'common.metadata'|trans({}, 'messages') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <dl class="row mb-0">
                        <dt class="col-sm-3 text-muted">{{ 'common.created_at'|trans({}, 'messages') }}</dt>
                        <dd class="col-sm-9">{{ review.createdAt|date('d.m.Y H:i') }}</dd>

                        <dt class="col-sm-3 text-muted">{{ 'common.updated_at'|trans({}, 'messages') }}</dt>
                        <dd class="col-sm-9">{{ review.updatedAt ? review.updatedAt|date('d.m.Y H:i') : '-' }}</dd>

                        <dt class="col-sm-3 text-muted">{{ 'common.id'|trans({}, 'messages') }}</dt>
                        <dd class="col-sm-9"><code>{{ review.id }}</code></dd>
                    </dl>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
