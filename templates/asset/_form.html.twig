{#
    Asset Form Partial (Accessible)
    Used by both new.html.twig and edit.html.twig

    WCAG 2.1 AA Compliant Form with:
    - Proper ARIA attributes
    - Error handling
    - Help texts
    - Required field indicators
#}

{% trans_default_domain 'assets' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{# Basic Information Section #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">
        <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
        {{ 'asset.section.basic_info'|trans({}, 'asset') }}
    </legend>

    <div class="row">
        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.name,
                'label_key': 'asset.field.name',
                'help_key': 'asset.help.name',
                'translation_domain': 'assets',
                'required': true
            } %}
        </div>

        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.assetType,
                'label_key': 'asset.field.type',
                'help_key': 'asset.help.type',
                'translation_domain': 'assets',
                'required': true
            } %}
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            {% include '_components/_form_field.html.twig' with {
                'field': form.description,
                'label_key': 'asset.field.description',
                'help_key': 'asset.help.description',
                'translation_domain': 'assets'
            } %}
        </div>
    </div>
</fieldset>

{# Assignment Section #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">
        <i class="fa-icon fa-icon--ui-person" aria-hidden="true"></i>
        {{ 'asset.section.assignment'|trans({}, 'asset') }}
    </legend>

    <div class="row">
        <div class="col-md-4">
            {{ form_row(form.ownerUser) }}
        </div>
        <div class="col-md-4">
            {{ form_row(form.ownerPerson) }}
        </div>
        <div class="col-md-4">
            {{ form_row(form.ownerDeputyPersons) }}
        </div>
    </div>
    <div class="row">
        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.owner,
                'label_key': 'asset.field.owner',
                'help_key': 'asset.help.owner',
                'translation_domain': 'assets'
            } %}
        </div>

        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.location,
                'label_key': 'asset.field.location',
                'help_key': 'asset.help.location',
                'translation_domain': 'assets'
            } %}
        </div>
    </div>
</fieldset>

{# Financial Information Section #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">
        <i class="bi bi-currency-dollar" aria-hidden="true"></i>
        {{ 'asset.section.financial'|trans({}, 'asset') }}
    </legend>

    <div class="row">
        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.acquisitionValue,
                'label_key': 'asset.field.acquisition_value',
                'help_key': 'asset.help.acquisition_value',
                'tooltip_key': 'asset.tooltip.acquisition_value',
                'translation_domain': 'asset'
            } %}
        </div>

        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.currentValue,
                'label_key': 'asset.field.current_value',
                'help_key': 'asset.help.current_value',
                'tooltip_key': 'asset.tooltip.current_value',
                'translation_domain': 'asset'
            } %}
        </div>

        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.monetaryValue,
                'label_key': 'asset.field.monetary_value',
                'help_key': 'asset.help.monetary_value',
                'tooltip_key': 'asset.tooltip.monetary_value',
                'translation_domain': 'asset'
            } %}
        </div>
    </div>
</fieldset>

{# CIA Values Section (Information Security) #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">
        <i class="bi bi-shield-lock" aria-hidden="true"></i>
        {{ 'asset.section.cia_values'|trans({}, 'asset') }}
    </legend>

    {{ _fa_alert.render({ variant: 'info', body: 'asset.cia_help'|trans({}, 'asset') }) }}

    <div class="row">
        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.confidentialityValue,
                'label_key': 'asset.field.confidentiality',
                'tooltip_key': 'asset.tooltip.confidentiality',
                'translation_domain': 'asset'
            } %}
        </div>

        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.integrityValue,
                'label_key': 'asset.field.integrity',
                'tooltip_key': 'asset.tooltip.integrity',
                'translation_domain': 'asset'
            } %}
        </div>

        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.availabilityValue,
                'label_key': 'asset.field.availability',
                'tooltip_key': 'asset.tooltip.availability',
                'translation_domain': 'asset'
            } %}
        </div>
    </div>
</fieldset>

{# AI-Agent Section — only visible when assetType = 'ai_agent' (EU AI Act / ISO 42001) #}
{# Wrapper uses the existing `conditional-fields` controller which toggles each
   field row whose `data-depends-on` references the asset_form_assetType select. #}
<div data-controller="conditional-fields asset-form">
    <fieldset class="mb-4"
              data-asset-form-target="aiAgentSection"
              data-depends-on="asset_form_assetType"
              data-depends-on-value="ai_agent">
        <legend class="h5 mb-3">
            <i class="fa-icon fa-icon--nav-robot" aria-hidden="true"></i>
            {{ 'asset.ai_agent.section.title'|trans({}, 'asset') }}
            <small class="text-muted ms-2">{{ 'asset.ai_agent.section.subtitle'|trans({}, 'asset') }}</small>
        </legend>

        <div class="alert alert-info" role="status">
            <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
            {{ 'asset.ai_agent.section.help'|trans({}, 'asset') }}
        </div>

        {# Provider suggestion list (datalist) — populated from the AI risk
           decision matrix. Keeping vendor names here is intentional: they are
           pre-classification suggestions, not endorsements. #}
        <datalist id="asset_ai_agent_provider_suggestions">
            <option value="Anthropic"></option>
            <option value="OpenAI"></option>
            <option value="Google"></option>
            <option value="Microsoft"></option>
            <option value="Self-hosted"></option>
        </datalist>

        <div class="row">
            <div class="col-md-6">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentClassification,
                    'label_key': 'asset.ai_agent.field.classification',
                    'help_key': 'asset.ai_agent.help.classification',
                    'translation_domain': 'asset'
                } %}
            </div>
            <div class="col-md-6">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentProvider,
                    'label_key': 'asset.ai_agent.field.provider',
                    'help_key': 'asset.ai_agent.help.provider',
                    'translation_domain': 'asset'
                } %}
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentModelVersion,
                    'label_key': 'asset.ai_agent.field.model_version',
                    'help_key': 'asset.ai_agent.help.model_version',
                    'translation_domain': 'asset'
                } %}
            </div>
            <div class="col-md-6">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentOversightMechanism,
                    'label_key': 'asset.ai_agent.field.oversight_mechanism',
                    'help_key': 'asset.ai_agent.help.oversight_mechanism',
                    'translation_domain': 'asset'
                } %}
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentPurpose,
                    'label_key': 'asset.ai_agent.field.purpose',
                    'help_key': 'asset.ai_agent.help.purpose',
                    'translation_domain': 'asset'
                } %}
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentDataSources,
                    'label_key': 'asset.ai_agent.field.data_sources',
                    'help_key': 'asset.ai_agent.help.data_sources',
                    'translation_domain': 'asset'
                } %}
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentCapabilityScope,
                    'label_key': 'asset.ai_agent.field.capability_scope',
                    'help_key': 'asset.ai_agent.help.capability_scope',
                    'translation_domain': 'asset'
                } %}
            </div>
            <div class="col-md-6">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentExtensionAllowlist,
                    'label_key': 'asset.ai_agent.field.extension_allowlist',
                    'help_key': 'asset.ai_agent.help.extension_allowlist',
                    'translation_domain': 'asset'
                } %}
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.aiAgentThreatModelDocId,
                    'label_key': 'asset.ai_agent.field.threat_model_doc_id',
                    'help_key': 'asset.ai_agent.help.threat_model_doc_id',
                    'translation_domain': 'asset'
                } %}
            </div>
        </div>
    </fieldset>
</div>

{# Form Actions #}
<div class="form-actions d-flex gap-2 justify-content-end">
    <a href="{{ path('app_asset_index') }}"
       class="fa-cyber-btn fa-cyber-btn--ghost">
        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
        {{ 'common.cancel'|trans({}, 'messages') }}
    </a>

    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
        <i class="{{ button_icon|default('bi-save') }}" aria-hidden="true"></i>
        {{ button_label|default('common.save'|trans({}, 'messages')) }}
    </button>
</div>
