{% extends 'base.html.twig' %}
{% trans_default_domain 'privacy' %}
{% block title %}{{ 'dpia.new.title'|trans({}, 'privacy')}}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'dpia.new.breadcrumb_gdpr'|trans({}, 'privacy'), icon: 'bi-shield-check' },
            { label: 'dpia.new.breadcrumb_dpia'|trans({}, 'privacy'), url: path('app_dpia_index') },
            { label: 'dpia.new.breadcrumb_new'|trans({}, 'privacy') }
        ]
    } %}

    {% include '_components/_page_header.html.twig' with {
        title: 'dpia.new.page_title'|trans({}, 'privacy'),
        subtitle: 'dpia.new.page_subtitle'|trans({}, 'privacy'),
        icon: 'bi-plus-circle',
        actions: [
            { label: 'dpia.new.button_cancel'|trans({}, 'privacy'), url: path('app_dpia_index'), variant: 'secondary', icon: 'bi-x-lg' }
        ]
    } %}

    <div class="row">
        <div class="col-lg-8">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header"><h2 class="h5 mb-0"><i class="fa-icon fa-icon--audit-internal" aria-hidden="true"></i> {{ 'dpia.new.form_title'|trans({}, 'privacy')}}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {{ form_start(form) }}
                        {% include '_components/_auto_form.html.twig' with {
                            'form': form,
                            'sections': {
                                'basic_info': {
                                    'label': ('<i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i> ' ~ 'dpia.new.section_basic_info'|trans({}, 'privacy'))|raw,
                                    'fields': ['title', 'referenceNumber', 'processingActivity']
                                },
                                'processing_operations': {
                                    'label': ('<i class="fa-icon fa-icon--ui-settings" aria-hidden="true"></i> ' ~ 'dpia.new.section_processing_operations'|trans({}, 'privacy'))|raw,
                                    'fields': ['processingDescription', 'processingPurposes', 'dataCategories', 'dataSubjectCategories', 'estimatedDataSubjects', 'dataRetentionPeriod', 'dataFlowDescription']
                                },
                                'necessity_proportionality': {
                                    'label': ('<i class="bi bi-balance-scale" aria-hidden="true"></i> ' ~ 'dpia.new.section_necessity_proportionality'|trans({}, 'privacy'))|raw,
                                    'fields': ['necessityAssessment', 'proportionalityAssessment', 'legalBasis', 'legislativeCompliance']
                                },
                                'risk_assessment': {
                                    'label': ('<i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> ' ~ 'dpia.new.section_risk_assessment'|trans({}, 'privacy'))|raw,
                                    'fields': ['riskLevel', 'likelihood', 'impact', 'dataSubjectRisks']
                                },
                                'measures': {
                                    'label': ('<i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> ' ~ 'dpia.new.section_measures'|trans({}, 'privacy'))|raw,
                                    'fields': ['technicalMeasures', 'organizationalMeasures', 'implementedControls', 'complianceMeasures', 'residualRiskAssessment', 'residualRiskLevel']
                                },
                                'consultation': {
                                    'label': ('<i class="fa-icon fa-icon--group" aria-hidden="true"></i> ' ~ 'dpia.new.section_consultation'|trans({}, 'privacy'))|raw,
                                    'fields': ['dataProtectionOfficer', 'dataProtectionOfficerPerson', 'dataProtectionOfficerDeputyPersons', 'dpoConsultationDate', 'dpoAdvice', 'dataSubjectsConsulted', 'dataSubjectConsultationDetails']
                                },
                                'supervisory': {
                                    'label': ('<i class="fa-icon fa-icon--nav-building" aria-hidden="true"></i> ' ~ 'dpia.new.section_supervisory'|trans({}, 'privacy'))|raw,
                                    'fields': ['requiresSupervisoryConsultation', 'supervisoryConsultationDate', 'supervisoryAuthorityFeedback']
                                },
                                'workflow': {
                                    'label': ('<i class="fa-icon fa-icon--recovery" aria-hidden="true"></i> ' ~ 'dpia.new.section_workflow'|trans({}, 'privacy'))|raw,
                                    'fields': ['conductor', 'conductorPerson', 'conductorDeputyPersons', 'approverPerson', 'approverDeputyPersons', 'reviewFrequencyMonths', 'nextReviewDate']
                                }
                            },
                            'col_widths': {
                                'title': 8,
                                'referenceNumber': 4,
                                'processingActivity': 12,
                                'processingDescription': 12,
                                'processingPurposes': 12,
                                'dataCategories': 12,
                                'dataSubjectCategories': 12,
                                'estimatedDataSubjects': 6,
                                'dataRetentionPeriod': 6,
                                'dataFlowDescription': 12,
                                'necessityAssessment': 12,
                                'proportionalityAssessment': 12,
                                'legalBasis': 6,
                                'legislativeCompliance': 6,
                                'riskLevel': 4,
                                'likelihood': 4,
                                'impact': 4,
                                'dataSubjectRisks': 12,
                                'technicalMeasures': 12,
                                'organizationalMeasures': 12,
                                'implementedControls': 12,
                                'complianceMeasures': 12,
                                'residualRiskAssessment': 6,
                                'residualRiskLevel': 6,
                                'dataProtectionOfficer': 6,
                                'dataProtectionOfficerPerson': 6,
                                'dataProtectionOfficerDeputyPersons': 12,
                                'dpoConsultationDate': 6,
                                'dpoAdvice': 12,
                                'dataSubjectsConsulted': 12,
                                'dataSubjectConsultationDetails': 12,
                                'requiresSupervisoryConsultation': 12,
                                'supervisoryConsultationDate': 6,
                                'supervisoryAuthorityFeedback': 6,
                                'conductor': 6,
                                'conductorPerson': 6,
                                'conductorDeputyPersons': 12,
                                'approverPerson': 6,
                                'approverDeputyPersons': 6,
                                'reviewFrequencyMonths': 6,
                                'nextReviewDate': 6
                            },
                            'translation_domain': 'privacy'
                        } %}

                        <div class="mt-4">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'dpia.new.button_create'|trans({}, 'privacy')}}
                            </button>
                            <a href="{{ path('app_dpia_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i> {{ 'dpia.new.button_cancel_bottom'|trans({}, 'privacy')}}
                            </a>
                        </div>
                    {{ form_end(form) }}
                {% endblock %}
            {% endembed %}
        </div>{# /col-lg-8 #}

        <div class="col-lg-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="h5 mb-0">
                            <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i>
                            {{ 'dpia.sidebar.title'|trans({}, 'privacy') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <h3 class="h6 text-primary">{{ 'dpia.sidebar.what_title'|trans({}, 'privacy') }}</h3>
                    <p class="small">{{ 'dpia.sidebar.what_text'|trans({}, 'privacy') }}</p>

                    <h3 class="h6 text-primary">{{ 'dpia.sidebar.when_title'|trans({}, 'privacy') }}</h3>
                    <p class="small">{{ 'dpia.sidebar.when_text'|trans({}, 'privacy') }}</p>

                    <h3 class="h6 text-primary">{{ 'dpia.sidebar.elements_title'|trans({}, 'privacy') }}</h3>
                    <ul class="list-unstyled small">
                        <li class="mb-1"><i class="fa-icon fa-icon--status-ok text-success me-1" aria-hidden="true"></i> {{ 'dpia.sidebar.elements_a'|trans({}, 'privacy') }}</li>
                        <li class="mb-1"><i class="fa-icon fa-icon--status-ok text-success me-1" aria-hidden="true"></i> {{ 'dpia.sidebar.elements_b'|trans({}, 'privacy') }}</li>
                        <li class="mb-1"><i class="fa-icon fa-icon--status-ok text-success me-1" aria-hidden="true"></i> {{ 'dpia.sidebar.elements_c'|trans({}, 'privacy') }}</li>
                        <li class="mb-1"><i class="fa-icon fa-icon--status-ok text-success me-1" aria-hidden="true"></i> {{ 'dpia.sidebar.elements_d'|trans({}, 'privacy') }}</li>
                    </ul>

                    <h3 class="h6 text-primary">{{ 'dpia.sidebar.consultation_title'|trans({}, 'privacy') }}</h3>
                    <p class="small mb-0">{{ 'dpia.sidebar.consultation_text'|trans({}, 'privacy') }}</p>
                {% endblock %}
            {% endembed %}
        </div>{# /col-lg-4 #}
    </div>{# /row #}
</div>
{% endblock %}
