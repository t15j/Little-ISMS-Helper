{% extends 'base.html.twig' %}
{% trans_default_domain 'data_subject_request' %}

{% block title %}{{ 'dsr.page.edit_title'|trans({}, 'data_subject_request') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'dsr.breadcrumb.privacy'|trans({}, 'data_subject_request'), icon: 'bi-shield-lock' },
            { label: 'dsr.breadcrumb.data_subject_requests'|trans({}, 'data_subject_request'), url: path('app_data_subject_request_index') },
            { label: '#' ~ dsr.id, url: path('app_data_subject_request_show', {id: dsr.id}) },
            { label: 'dsr.page.edit_title'|trans({}, 'data_subject_request') }
        ]
    } only %}

    {% include '_components/_page_header.html.twig' with {
        title: 'dsr.page.edit_title'|trans({}, 'data_subject_request'),
        subtitle: dsr.dataSubjectName ~ ' - ' ~ ('dsr.type.' ~ dsr.requestType)|trans({}, 'data_subject_request'),
        icon: 'bi-pencil-square',
        actions: [
            { label: 'common.cancel'|trans({}, 'messages'), url: path('app_data_subject_request_show', {id: dsr.id}), variant: 'secondary', icon: 'bi-x-lg' }
        ]
    } only %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0"><i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'dsr.form.title'|trans({}, 'data_subject_request') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {{ form_start(form) }}
                {% include '_components/_auto_form.html.twig' with {
                    'form': form,
                    'sections': {
                        'request_details': {
                            'label': '<i class="fa-icon fa-icon--policy" aria-hidden="true"></i> ' ~ 'dsr.section.request_details'|trans({}, 'data_subject_request'),
                            'fields': ['requestType', 'receivedAt', 'description']
                        },
                        'data_subject_info': {
                            'label': '<i class="fa-icon fa-icon--user" aria-hidden="true"></i> ' ~ 'dsr.section.data_subject_info'|trans({}, 'data_subject_request'),
                            'fields': ['dataSubjectName', 'dataSubjectEmail', 'dataSubjectIdentifier']
                        },
                        'identity_verification': {
                            'label': '<i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> ' ~ 'dsr.section.identity_verification'|trans({}, 'data_subject_request'),
                            'fields': ['identityVerified', 'identityVerificationMethod']
                        },
                        'assignment': {
                            'label': '<i class="fa-icon fa-icon--role" aria-hidden="true"></i> ' ~ 'dsr.section.assignment'|trans({}, 'data_subject_request'),
                            'fields': ['assignedTo', 'assignedPerson', 'assignedDeputyPersons', 'processingActivity']
                        },
                        'internal': {
                            'label': '<i class="fa-icon fa-icon--nav-journal" aria-hidden="true"></i> ' ~ 'dsr.section.internal_notes'|trans({}, 'data_subject_request'),
                            'fields': ['notes']
                        }
                    },
                    'col_widths': {
                        'requestType': 6,
                        'receivedAt': 6,
                        'description': 12,
                        'dataSubjectName': 4,
                        'dataSubjectEmail': 4,
                        'dataSubjectIdentifier': 4,
                        'identityVerified': 6,
                        'identityVerificationMethod': 6,
                        'assignedTo': 6,
                        'assignedPerson': 6,
                        'assignedDeputyPersons': 12,
                        'processingActivity': 6,
                        'notes': 12
                    },
                    'translation_domain': 'data_subject_request'
                } %}

                <div class="mt-4">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                        <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'dsr.action.save'|trans({}, 'data_subject_request') }}
                    </button>
                    <a href="{{ path('app_data_subject_request_show', {id: dsr.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i> {{ 'common.cancel'|trans({}, 'messages') }}
                    </a>
                </div>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
